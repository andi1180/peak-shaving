# Peak Shaving Kalkulator — Environment-Vorlage
# Kopieren nach .env.local (wird nicht committet). Keine echten Werte hier eintragen.
# Supabase kommt in einem späteren Prompt (Portal, §4/§9) — Platzhalter bereits jetzt.

# Öffentliche Supabase-URL (Client + Server). NEXT_PUBLIC_* ist im Browser sichtbar.
# NEXT_PUBLIC_SUPABASE_URL=

# Öffentlicher Anon-Key (Client). Nur mit RLS sicher — schützt keine Daten für sich.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-Role-Key (NUR serverseitig, umgeht RLS). Niemals an den Client geben.
# SUPABASE_SERVICE_ROLE_KEY=
