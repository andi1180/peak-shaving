# Peak Shaving Kalkulator / CoolIn-Plattform — Environment-Vorlage
# Kopieren nach .env.local (wird nicht committet). Keine echten Werte hier eintragen.
# EIN Supabase-Projekt für die ganze Plattform (Kalkulator-Portal + Monitor, Produkt-Trennung
# über Postgres-Schemas, nicht über separate Projekte — s. packages/tariff-monitor/CLAUDE.md).

# Öffentliche Supabase-URL (Client + Server). NEXT_PUBLIC_* ist im Browser sichtbar.
NEXT_PUBLIC_SUPABASE_URL=

# Öffentlicher Anon-Key (Client). Nur mit RLS sicher — schützt keine Daten für sich.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-Role-Key (NUR serverseitig, umgeht RLS). Niemals an den Client geben, NIE committen.
SUPABASE_SERVICE_ROLE_KEY=
